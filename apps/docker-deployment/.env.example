# Loomind Docker Deployment — Environment Overrides
# Copy this file to .env and uncomment/edit the values you want to change.
# All variables have defaults in docker-compose.yml — this file is optional.
#
# Usage:
#   cp .env.example .env
#   # edit .env as needed
#   docker compose up -d

# ── Ports ────────────────────────────────────────────────────
# ENGINE_PORT=8082

# ── Engine ───────────────────────────────────────────────────
# ENGINE_LOG_LEVEL=info          # debug | info | warning | error
# LOG_FORMAT=json                # json | text

# ── Qdrant ───────────────────────────────────────────────────
# QDRANT_MODE=server             # server | local
# QDRANT_URL=http://qdrant:6333
# QDRANT_COLLECTION=experiences

# ── Embeddings ───────────────────────────────────────────────
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cpu           # cpu | cuda

# ── LLM (Ollama on host) ─────────────────────────────────────
# LLM_PROVIDER=ollama            # ollama | llamacpp
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2:3b
# LLAMACPP_URL=http://host.docker.internal:8080

# ── Rate limits ──────────────────────────────────────────────
# INTERCEPT_RATE_LIMIT=120
# EXTRACT_RATE_LIMIT=60

# ── Background worker ────────────────────────────────────────
# ENABLE_JUDGE_WORKER=true
# JUDGE_BATCH_INTERVAL=5
# EVOLVE_INTERVAL_MINUTES=30

# ── Agentic Brain (Phase 11) ─────────────────────────────────
# HITL_TIMEOUT_SECONDS=180       # SECURITY tasks always require approval regardless
# MAX_TASK_RETRIES=3
# GOAL_DB_PATH=/app/data/goals.db

# ── Notifications (OFF by default) ───────────────────────────
# NOTIFICATION_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── CLI Bridge (host-side subprocess proxy) ──────────────────
# CLI_BRIDGE_URL=http://host.docker.internal:8083
# CLI_TIMEOUT=120
# On Linux: use host IP or enable extra_hosts in docker-compose.yml
