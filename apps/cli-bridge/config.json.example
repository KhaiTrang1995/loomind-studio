{
  "enabled_clis": ["claude", "grok", "agy"],
  "cli_timeout": 300,
  "poll_interval": 15,
  "max_iterations": 3,
  "engine_url": "http://localhost:8082",
  "cli_paths": {
    "claude": "/path/to/claude",
    "grok":   "/path/to/grok",
    "agy":    "/path/to/agy",
    "codex":  "/path/to/codex"
  }
}
